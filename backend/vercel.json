{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/script.js", "destination": "/public/script.js" },
    { "source": "/sw.js", "destination": "/public/sw.js" },
    { "source": "/manifest.json", "destination": "/public/manifest.json" },
    { "source": "/capacitor.js", "destination": "/public/capacitor.js" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}